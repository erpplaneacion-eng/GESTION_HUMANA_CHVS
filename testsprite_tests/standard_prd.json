            "/login/": {
              "get": {
                "summary": "Obtener formulario de login",
                "responses": {
                  "200": {
                    "description": "Página de login HTML"
                  }
                }
              },
              "post": {
                "summary": "Autenticar usuario administrador",
                "requestBody": {
                  "required": true,
                  "content": {
                    "application/x-www-form-urlencoded": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "username": {
                            "type": "string"
                          },
                          "password": {
                            "type": "string",
                            "format": "password"
                          }
                        },
                        "required": [
