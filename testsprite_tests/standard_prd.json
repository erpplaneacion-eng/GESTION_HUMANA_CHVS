      {
        "name": "Búsqueda de Experiencia Histórica",
        "description": "Consulta de datos históricos (2017-2025) por cédula: experiencia total consolidada, URL de carpeta, historial de contratos con traslapes calculados, y datos del consolidado de contratos",
        "files": [
          "gestion_humana/basedatosaquicali/views.py",
          "gestion_humana/basedatosaquicali/templates/basedatosaquicali/busqueda_historica.html",
          "gestion_humana/basedatosaquicali/models.py"
        ],
        "api_doc": {
          "openapi": "3.0.0",
          "info": {
            "title": "API de Búsqueda Histórica",
            "version": "1.0.0"
          },
          "paths": {
            "/historico/buscar/": {
              "get": {
                "summary": "Buscar experiencia histórica por cédula",
                "parameters": [
                  {
                    "name": "q",
                    "in": "query",
                    "required": true,
                    "schema": {
                      "type": "string"
                    },
                    "description": "Número de cédula"
                  }
                ],
                "responses": {
                  "200": {
                    "description": "Datos históricos del contratista",
                    "content": {
                      "text/html": {
                        "schema": {
                          "type": "object",
                          "properties": {
                            "experiencia_total": {
                              "type": "object",
                              "properties": {
                                "experiencia_bruta_dias": {
                                  "type": "integer"
                                },
                                "experiencia_neta_dias": {
                                  "type": "integer"
                                },
                                "experiencia_neta_texto": {
                                  "type": "string"
                                }
                              }
                            },
                            "url": {
                              "type": "object",
                              "properties": {
                                "enlace_carpeta": {
                                  "type": "string",
                                  "format": "uri"
                                }
                              }
                            },
                            "historial": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "contrato": {
                                    "type": "string"
                                  },
                                  "fecha_inicio": {
                                    "type": "string",
                                    "format": "date"
                                  },
                                  "fecha_fin": {
                                    "type": "string",
