        "name": "Gestión de Archivos en Cloudinary",
        "description": "Sistema centralizado de almacenamiento de archivos en la nube con validaciones robustas: tamaño máximo 10MB, formatos PDF/JPG/PNG, validación MIME, prevención de re-validación en ediciones",
        "files": [
          "gestion_humana/formapp/validators.py",
          "gestion_humana/formapp/models.py",
          "gestion_humana/gestion_humana/settings.py"
        ],
        "api_doc": {
          "openapi": "3.0.0",
          "info": {
            "title": "API de Gestión de Archivos",
            "version": "1.0.0"
          },
          "paths": {
            "/formapp/upload-file/": {
              "post": {
                "summary": "Subir archivo a Cloudinary",
                "description": "Validaciones: tamaño máx 10MB, formatos permitidos PDF/JPG/PNG/JPEG, validación MIME con python-magic",
                "requestBody": {
                  "required": true,
                  "content": {
                    "multipart/form-data": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "file": {
                            "type": "string",
                            "format": "binary"
                          },
                          "file_type": {
                            "type": "string",
                            "enum": [
                              "identity",
                              "academic",
                              "experience",
                              "antecedent",
                              "annex"
                            ]
                          }
                        }
                      }
                    }
                  }
                },
                "responses": {
                  "200": {
                    "description": "Archivo subido exitosamente a Cloudinary",
                    "content": {
                      "application/json": {
                        "schema": {
                          "type": "object",
                          "properties": {
                            "file_url": {
                              "type": "string",
                              "format": "uri"
                            }
                          }
                        }
                      }
                    }
                  },
                  "400": {
                    "description": "Error de validación: tamaño excedido o formato no permitido"
                  }
                }
              }
            }
          }
        }
